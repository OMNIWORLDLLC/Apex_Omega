{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "start": "node dist/server.cjs",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "test:contract-sync": "tsx scripts/contract-sync-test.ts",
    "test:signing-hash": "tsx scripts/signing-hash-test.ts",
    "test:broadcast": "tsx scripts/broadcast-test.ts",
    "proof:strategy": "tsx scripts/strategy-proof-audit.ts",
    "routes:dynamic": "tsx scripts/dynamic-route-audit.ts",
    "routes:verify": "tsx scripts/route-engine-verify.ts",
    "fork:calldata": "tsx scripts/fork-calldata-sim.ts",
    "cloud:readiness": "tsx scripts/cloud-readiness.ts",
    "live:cycle": "tsx scripts/live-cycle.ts",
    "perf:metrics": "tsx scripts/perf-metrics.ts",
    "perf:metrics:snapshot": "tsx scripts/perf-metrics.ts -- --snapshot"
  },
  "dependencies": {
    "@google/genai": "^1.52.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "canvas-confetti": "^1.9.4",
    "dotenv": "^17.2.3",
    "ethers": "^6.17.0",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "vite": "^6.2.3",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/canvas-confetti": "^1.9.0",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/ws": "^8.18.1",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.28.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
