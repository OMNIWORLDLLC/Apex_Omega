# --- Redis Distributed Route Guard ---
# Prevents PM2 cluster workers and overlapping async cycles from racing to
# execute the same arbitrage route or liquidation.
# When running via docker-compose the REDIS_URL is injected automatically.
# For bare-metal / PM2 deployments set REDIS_URL to your Redis instance.
# Leave unset to run in single-process no-op mode (Redis not required).
REDIS_URL="redis://:apex_redis_secret@localhost:6379"
REDIS_PASSWORD="apex_redis_secret"

