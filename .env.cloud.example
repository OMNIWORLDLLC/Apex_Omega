# Redis execution ledger.
# Preserves route evaluations and execution locks so new scans do not overwrite
# candidates that are being re-evaluated, fork-simulated, or submitted.
REDIS_ENABLED=true
REDIS_REQUIRED_FOR_LIVE=true
REDIS_ARCHITECTURE=hot_path_execution_ledger
REDIS_URL=redis://redis:6379
REDIS_KEY_PREFIX=apex:omega
REDIS_OPPORTUNITY_TTL_MS=120000
REDIS_EXECUTION_LOCK_TTL_MS=45000
LIVE_QUOTE_LANES=32
TOP_ROUTE_DISPLAY_LIMIT=50
C1_EXECUTABLE_LIMIT_PER_CYCLE=10
C2_PER_C1_LIMIT=5
C2_DECISION_LIMIT_PER_CYCLE=50
