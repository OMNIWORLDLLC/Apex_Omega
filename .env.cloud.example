# Apex Omega cloud runtime template
# Copy to your cloud secret manager or to a local .env.production file.
# Do not bake this file or real secrets into the Docker image.

NODE_ENV=production
PORT=3000
CHAIN_ID=137
APEX_CHAIN_ID=137
REQUIRE_CHAIN_ID_MATCH=true
RPC_REQUIRE_CHAIN_ID=137

# Default deploy posture is monitor-only. For real execution set:
# LIVE_EXECUTION=true
# SHADOW_MODE=false
LIVE_EXECUTION=false
SHADOW_MODE=true

# Required live Polygon read/broadcast RPC.
POLYGON_RPC_URL=
DISCOVERY_RPC_URL=
RPC_URL=

# Redis execution ledger.
# Preserves route evaluations and execution locks so new scans do not overwrite
# candidates that are being re-evaluated, fork-simulated, or submitted.
REDIS_ENABLED=true
REDIS_URL=redis://redis:6379
REDIS_KEY_PREFIX=apex:omega
REDIS_OPPORTUNITY_TTL_MS=120000
REDIS_EXECUTION_LOCK_TTL_MS=45000
LIVE_QUOTE_LANES=32
C2_LISTENER_ENABLED=true

# Required production fork-simulation RPC.
# Live C1, C2, and liquidation broadcasts are blocked unless exact calldata simulation passes here.
FORK_UPSTREAM_RPC_URL=
FORK_RPC_URL=http://anvil-fork:8545
FORK_SIM_RPC_URL=http://anvil-fork:8545

# Signer secrets: set in cloud secret manager, never in image layers.
EXECUTOR_PRIVATE_KEY=
BOT_PRIVATE_KEY=
PRIVATE_KEY=

# P&L receiver and gates.
BOT_PROFIT_RECEIVER=0xaD3eF84259cFACB5D77a70911f85d39D2DBB49c6
PROFIT_RECIPIENT_ADDRESS=0xaD3eF84259cFACB5D77a70911f85d39D2DBB49c6
MIN_NET_PROFIT_USD=5.00

# Optional adapter overrides.
UNISWAP_V3_QUOTER=0xb27308f9F90D607463bb33eA1BeBb41C27CE5AB6
UNISWAP_V3_ROUTER=0xE592427A0AEce92De3Edee1F18E0157C05861564
ALGEBRA_FACTORY=0x411b0fAcC3489691f28ad58c47006AF5E3Ab3A28
ALGEBRA_QUOTER=0xa15F0D7377B2A0C0c10db057f641beD21028FC89
ALGEBRA_ROUTER=0xf5b509bB0909a69B1c207E495f687a596C168E12
BALANCER_VAULT=0xBA12222222228d8Ba445958a75a0704d566BF2C8
CURVE_ADDRESS_PROVIDER=0x0000000022D53366457F9d5E68Ec105046FC4383
