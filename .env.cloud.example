# Apex Omega cloud runtime template
# Copy to your cloud secret manager or to a local .env.production file.
# Do not bake this file or real secrets into the Docker image.

# --- System Environment Configuration ---
NODE_ENV="production"
PORT="3000"
CHAIN_ID="137"
APEX_CHAIN_ID="137"
REQUIRE_CHAIN_ID_MATCH="true"
RPC_REQUIRE_CHAIN_ID="137"
EXECUTION_MODE="LIVE"
LIVE_EXECUTION="true"
SHADOW_MODE="false"

